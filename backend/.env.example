# Supabase — required for DB operations and storage
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>

# ML services — not required for mock mode, needed for full pipeline
HUGGINGFACE_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# REQUIRED in production: comma-separated list of the real deployed frontend
# origin(s) (e.g. https://app.example.com,https://admin.example.com).
# Leaving this unset causes backend/main.py to default allow_origins to
# http://localhost:5173 (dev-only), which is incorrect for a deployed environment.
CORS_ORIGINS=
